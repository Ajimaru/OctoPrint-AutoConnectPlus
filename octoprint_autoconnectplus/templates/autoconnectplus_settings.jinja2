<form class="form-horizontal">
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        {{ _('AutoConnectPlus reconnects the printer using the connection you last configured in OctoPrint\'s connection dialog (serial, Moonraker, Bambu, ...). The connection parameters are taken from OctoPrint directly, so there is nothing to duplicate here.') }}
    </div>

    <div class="control-group">
        <div class="controls">
            <label class="checkbox">
                <input type="checkbox"
                       data-bind="checked: settings.plugins.autoconnectplus.enabled">
                {{ _('Enable automatic (re)connect') }}
            </label>
            <span class="help-block">
                {{ _('When disabled, AutoConnectPlus stays idle and never reconnects the printer.') }}
            </span>
        </div>
    </div>

    <div class="control-group">
        <label class="control-label">{{ _('Detected connection') }}</label>
        <div class="controls">
            <span class="help-block" style="margin-top: 5px;">
                <strong>{{ plugin_autoconnectplus_detected_label }}</strong>{% if plugin_autoconnectplus_detected_target %} &mdash; {{ plugin_autoconnectplus_detected_target }}{% endif %}
            </span>
            {% if plugin_autoconnectplus_detected_warning %}
            <span class="help-block text-warning">
                {{ plugin_autoconnectplus_detected_warning }}
            </span>
            {% endif %}
            <span class="help-block muted">
                {{ _('Read-only. Taken from OctoPrint\'s preferred connection.') }}
            </span>
        </div>
    </div>

    <div class="control-group">
        <label class="control-label">{{ _('Retry interval (seconds)') }}</label>
        <div class="controls">
            <input type="number" min="0.1" step="0.1"
                   data-bind="value: settings.plugins.autoconnectplus.interval">
            <span class="help-block">
                {{ _('How often to attempt a reconnect while the printer is disconnected.') }}
            </span>
        </div>
    </div>

    <div class="control-group">
        <label class="control-label">{{ _('Forced serial port') }}</label>
        <div class="controls">
            <input type="text" placeholder="/dev/ttyUSB0"
                   data-bind="value: settings.plugins.autoconnectplus.forced_port">
            <span class="help-block">
                {{ _('Serial connections only. Optional. Used only when OctoPrint\'s serial port is unset or AUTO.') }}
            </span>
        </div>
    </div>
</form>
